# Padrões para Git ignore
# Arquivos e pastas que não devem ser versionados

# Dependências
node_modules/
package-lock.json
yarn.lock

# Build outputs
dist/
build/
*.min.js
*.min.css

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~

# Sistema operacional
.DS_Store
Thumbs.db

# Arquivos temporários
*.tmp
*.bak
.temp/

# Logs
*.log
npm-debug.log*
yarn-debug.log*

# Ambiente
.env
.env.local
